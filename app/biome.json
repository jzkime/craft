{
	"$schema": "https://biomejs.dev/schemas/2.4.13/schema.json",
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true
	},
	"files": {
		"includes": [
			"app/packages/**/*.ts",
			"app/packages/**/*.tsx",
			"!!/node_modules",
			"!!/dist"
		]
	},
	"linter": {
		"enabled": true,
		"rules": {
			"complexity": { "noStaticOnlyClass": "off", "noUselessFragments": "off" },
			"recommended": true,
			"correctness": {
				"useExhaustiveDependencies": "off",
				"noUnusedImports": "error",
				"noUnusedVariables": { "level": "warn", "fix": "none" }
			},
			"suspicious": {
				"noConsole": "error"
			},
			"style": {
				"useBlockStatements": "error"
			}
		}
	},
	"javascript": {
		"formatter": {
			"bracketSameLine": false,
			"quoteStyle": "double",
			"indentStyle": "space",
			"indentWidth": 4,
			"lineWidth": 120,
			"lineEnding": "lf",
			"trailingCommas": "all"
		},
		"parser": { "unsafeParameterDecoratorsEnabled": true }
	},
	"assist": {
		"enabled": true,
		"actions": {
			"source": {
				"organizeImports": "on"
			}
		}
	}
}
